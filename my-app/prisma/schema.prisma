generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  male
  female
  other
}

enum ActivityLevel {
  sedentary
  lightly_active
  moderately_active
  very_active
}

enum FitnessGoal {
  lose_weight
  maintain
  gain_muscle
}

enum MealType {
  breakfast
  lunch
  dinner
  snack
}

enum PhotoStatus {
  pending
  success
  failed
}

enum WorkoutStatus {
  in_progress
  completed
  cancelled
}

enum SettingValueType {
  string
  number
  boolean
  json
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone        String    @unique @db.VarChar(15)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  isActive     Boolean   @default(true) @map("is_active")
  loginFailures Int      @default(0) @map("login_failures")
  lockedUntil   DateTime? @map("locked_until") @db.Timestamptz(6)
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  profile          UserProfile?
  dailyNutrition   DailyNutrition[]
  mealRecords      MealRecord[]
  foodPhotos       FoodPhoto[]
  healthChecklist  HealthChecklist[]
  healthScores     HealthScore[]
  workoutRecords   WorkoutRecord[]
  appSettings      AppSetting[]
  refreshTokens    RefreshToken[]

  @@index([phone], map: "idx_users_phone")
  @@map("users")
}

model UserProfile {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String        @unique @map("user_id") @db.Uuid
  nickname            String?       @db.VarChar(50)
  gender              Gender
  age                 Int
  heightCm            Decimal       @map("height_cm") @db.Decimal(5, 2)
  weightKg            Decimal       @map("weight_kg") @db.Decimal(5, 2)
  activityLevel       ActivityLevel @map("activity_level")
  fitnessGoal         FitnessGoal   @map("fitness_goal")
  dailyCalorieTarget  Int           @map("daily_calorie_target")
  dailyProteinTargetG Int           @map("daily_protein_target_g")
  dailyCarbsTargetG   Int           @map("daily_carbs_target_g")
  dailyFatTargetG     Int           @map("daily_fat_target_g")
  waterTargetMl       Int           @default(2000) @map("water_target_ml")
  sleepTargetHours    Decimal       @default(7.5) @map("sleep_target_hours") @db.Decimal(3, 1)
  updatedAt           DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_profiles_user_id")
  @@map("user_profiles")
}

model DailyNutrition {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  recordDate     DateTime @map("record_date") @db.Date
  totalCalories  Int      @default(0) @map("total_calories")
  totalProteinG  Decimal  @default(0) @map("total_protein_g") @db.Decimal(6, 2)
  totalCarbsG    Decimal  @default(0) @map("total_carbs_g") @db.Decimal(6, 2)
  totalFatG      Decimal  @default(0) @map("total_fat_g") @db.Decimal(6, 2)
  caloriesTarget Int      @map("calories_target")
  proteinTargetG Int      @map("protein_target_g")
  carbsTargetG   Int      @map("carbs_target_g")
  fatTargetG     Int      @map("fat_target_g")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, recordDate])
  @@index([userId, recordDate(sort: Desc)], map: "idx_daily_nutrition_user_date")
  @@map("daily_nutrition")
}

model FoodCategory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique @db.VarChar(50)
  sortOrder Int      @default(0) @map("sort_order")
  icon      String?  @db.VarChar(50)
  isSystem  Boolean  @default(true) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  foodItems FoodItem[]

  @@index([sortOrder], map: "idx_food_categories_sort")
  @@map("food_categories")
}

model FoodItem {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String   @db.VarChar(100)
  categoryId      String   @map("category_id") @db.Uuid
  caloriesPer100g Int      @map("calories_per_100g")
  proteinPer100g  Decimal  @default(0) @map("protein_per_100g") @db.Decimal(6, 2)
  carbsPer100g    Decimal  @default(0) @map("carbs_per_100g") @db.Decimal(6, 2)
  fatPer100g      Decimal  @default(0) @map("fat_per_100g") @db.Decimal(6, 2)
  unit            String   @default("g") @db.VarChar(20)
  isSystem        Boolean  @default(true) @map("is_system")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  category  FoodCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  mealFoods MealFood[]

  @@index([categoryId], map: "idx_food_items_category")
  @@index([name], map: "idx_food_items_name")
  @@index([isSystem, isActive], map: "idx_food_items_system_active")
  @@map("food_items")
}

model MealRecord {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  recordDate    DateTime @map("record_date") @db.Date
  mealType      MealType @map("meal_type")
  totalCalories Int      @default(0) @map("total_calories")
  totalProteinG Decimal  @default(0) @map("total_protein_g") @db.Decimal(6, 2)
  totalCarbsG   Decimal  @default(0) @map("total_carbs_g") @db.Decimal(6, 2)
  totalFatG     Decimal  @default(0) @map("total_fat_g") @db.Decimal(6, 2)
  note          String?  @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealFoods MealFood[]

  @@index([userId, recordDate(sort: Desc)], map: "idx_meal_records_user_date")
  @@index([userId, recordDate, mealType], map: "idx_meal_records_user_date_type")
  @@map("meal_records")
}

model MealFood {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mealRecordId       String   @map("meal_record_id") @db.Uuid
  foodItemId         String   @map("food_item_id") @db.Uuid
  quantityG          Decimal  @map("quantity_g") @db.Decimal(6, 2)
  calculatedCalories Int      @map("calculated_calories")
  calculatedProteinG Decimal  @map("calculated_protein_g") @db.Decimal(6, 2)
  calculatedCarbsG   Decimal  @map("calculated_carbs_g") @db.Decimal(6, 2)
  calculatedFatG     Decimal  @map("calculated_fat_g") @db.Decimal(6, 2)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  mealRecord MealRecord @relation(fields: [mealRecordId], references: [id], onDelete: Cascade)
  foodItem   FoodItem   @relation(fields: [foodItemId], references: [id], onDelete: Restrict)

  @@index([mealRecordId], map: "idx_meal_foods_meal")
  @@index([foodItemId], map: "idx_meal_foods_food")
  @@map("meal_foods")
}

model FoodPhoto {
  id                 String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String      @map("user_id") @db.Uuid
  recognizedFoodName String?     @map("recognized_food_name") @db.VarChar(100)
  proteinG           Decimal?    @map("protein_g") @db.Decimal(6, 2)
  carbsG             Decimal?    @map("carbs_g") @db.Decimal(6, 2)
  fatG               Decimal?    @map("fat_g") @db.Decimal(6, 2)
  status             PhotoStatus @default(pending)
  errorMessage       String?     @map("error_message")
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt        DateTime?   @map("completed_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)], map: "idx_food_photos_user")
  @@map("food_photos")
}

model HealthChecklist {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  recordDate       DateTime @map("record_date") @db.Date
  waterIntake      Boolean  @default(false) @map("water_intake")
  sleepQuality     Boolean  @default(false) @map("sleep_quality")
  exerciseDone     Boolean  @default(false) @map("exercise_done")
  waterIntakeMl    Int      @default(0) @map("water_intake_ml")
  sleepActualHours Decimal? @map("sleep_actual_hours") @db.Decimal(3, 1)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, recordDate])
  @@index([userId, recordDate(sort: Desc)], map: "idx_health_checklist_user_date")
  @@map("health_checklist")
}

model HealthScore {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  recordDate     DateTime @map("record_date") @db.Date
  totalScore     Int      @map("total_score")
  grade          String   @db.VarChar(2)
  nutritionScore Int      @map("nutrition_score")
  exerciseScore  Int      @map("exercise_score")
  sleepScore     Int      @map("sleep_score")
  hydrationScore Int      @map("hydration_score")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, recordDate])
  @@index([userId, recordDate(sort: Desc)], map: "idx_health_scores_user_date")
  @@map("health_scores")
}

model ExerciseCategory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique @db.VarChar(50)
  sortOrder Int      @default(0) @map("sort_order")
  icon      String?  @db.VarChar(50)
  isSystem  Boolean  @default(true) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  exercises Exercise[]

  @@index([sortOrder], map: "idx_exercise_categories_sort")
  @@map("exercise_categories")
}

model Exercise {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String   @db.VarChar(100)
  categoryId         String   @map("category_id") @db.Uuid
  description        String?
  isCardio           Boolean  @default(false) @map("is_cardio")
  defaultSets        Int?     @map("default_sets")
  defaultReps        Int?     @map("default_reps")
  defaultDurationMin Int?     @map("default_duration_min")
  isSystem           Boolean  @default(true) @map("is_system")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  category         ExerciseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  workoutExercises WorkoutExercise[]

  @@index([categoryId], map: "idx_exercises_category")
  @@index([name], map: "idx_exercises_name")
  @@index([isCardio], map: "idx_exercises_cardio")
  @@index([isSystem, isActive], map: "idx_exercises_system_active")
  @@map("exercises")
}

model WorkoutRecord {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String        @map("user_id") @db.Uuid
  workoutDate        DateTime      @map("workout_date") @db.Date
  startTime          DateTime?     @map("start_time") @db.Timestamptz(6)
  endTime            DateTime?     @map("end_time") @db.Timestamptz(6)
  totalDurationMin   Int           @default(0) @map("total_duration_min")
  totalExercises     Int           @default(0) @map("total_exercises")
  totalSetsCompleted Int           @default(0) @map("total_sets_completed")
  status             WorkoutStatus @default(in_progress)
  notes              String?
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutExercises WorkoutExercise[]

  @@index([userId, workoutDate(sort: Desc)], map: "idx_workout_records_user_date")
  @@index([userId, status], map: "idx_workout_records_status")
  @@map("workout_records")
}

model WorkoutExercise {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workoutRecordId   String   @map("workout_record_id") @db.Uuid
  exerciseId        String   @map("exercise_id") @db.Uuid
  exerciseOrder     Int      @default(0) @map("exercise_order")
  setNumber         Int      @default(1) @map("set_number")
  weightKg          Decimal? @map("weight_kg") @db.Decimal(6, 2)
  reps              Int?
  durationMin       Decimal? @map("duration_min") @db.Decimal(5, 1)
  inclinePercent    Decimal? @map("incline_percent") @db.Decimal(4, 1)
  resistanceLevel   Int?     @map("resistance_level")
  loadSetting       String?  @map("load_setting") @db.VarChar(20)
  isCompleted       Boolean  @default(false) @map("is_completed")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  workoutRecord WorkoutRecord @relation(fields: [workoutRecordId], references: [id], onDelete: Cascade)
  exercise      Exercise      @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@index([workoutRecordId, exerciseOrder, setNumber], map: "idx_workout_exercises_workout")
  @@index([exerciseId], map: "idx_workout_exercises_exercise")
  @@map("workout_exercises")
}

model AppSetting {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  settingKey   String           @map("setting_key") @db.VarChar(100)
  settingValue String           @map("setting_value")
  valueType    SettingValueType @default(string) @map("value_type")
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, settingKey])
  @@index([userId, settingKey], map: "idx_app_settings_user_key")
  @@map("app_settings")
}

model SystemInfo {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appName              String   @map("app_name") @db.VarChar(100)
  appVersion           String   @map("app_version") @db.VarChar(20)
  buildNumber          String?  @map("build_number") @db.VarChar(20)
  releaseNotes         String?  @map("release_notes")
  privacyPolicyContent String?  @map("privacy_policy_content")
  developerName        String?  @map("developer_name") @db.VarChar(50)
  developerTitle       String?  @map("developer_title") @db.VarChar(50)
  isCurrent            Boolean  @default(false) @map("is_current")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([isCurrent], map: "idx_system_info_current")
  @@map("system_info")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)], map: "idx_refresh_tokens_user")
  @@index([tokenHash], map: "idx_refresh_tokens_hash")
  @@index([expiresAt], map: "idx_refresh_tokens_expires")
  @@map("refresh_tokens")
}
