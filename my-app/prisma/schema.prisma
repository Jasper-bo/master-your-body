generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Gender {
  male
  female
  other
}

enum ActivityLevel {
  sedentary
  lightly_active
  moderately_active
  very_active
}

enum FitnessGoal {
  lose_weight
  maintain
  gain_muscle
}

enum MealType {
  breakfast
  lunch
  dinner
  snack
}

enum PhotoStatus {
  pending
  success
  failed
}

enum WorkoutStatus {
  in_progress
  completed
  cancelled
}

enum SettingValueType {
  string
  number
  boolean
  json
}

model User {
  id            String    @id @default(uuid())
  phone         String    @unique
  passwordHash  String    @map("password_hash")
  isActive      Boolean   @default(true) @map("is_active")
  loginFailures Int       @default(0) @map("login_failures")
  lockedUntil   DateTime? @map("locked_until")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  profile         UserProfile?
  dailyNutrition  DailyNutrition[]
  mealRecords     MealRecord[]
  foodPhotos      FoodPhoto[]
  healthChecklist HealthChecklist[]
  healthScores    HealthScore[]
  workoutRecords  WorkoutRecord[]
  appSettings     AppSetting[]
  refreshTokens   RefreshToken[]

  @@index([phone], map: "idx_users_phone")
  @@map("users")
}

model UserProfile {
  id                  String        @id @default(uuid())
  userId              String        @unique @map("user_id")
  nickname            String?
  gender              Gender
  age                 Int
  heightCm            Decimal       @map("height_cm")
  weightKg            Decimal       @map("weight_kg")
  activityLevel       ActivityLevel @map("activity_level")
  fitnessGoal         FitnessGoal   @map("fitness_goal")
  dailyCalorieTarget  Int           @map("daily_calorie_target")
  dailyProteinTargetG Int           @map("daily_protein_target_g")
  dailyCarbsTargetG   Int           @map("daily_carbs_target_g")
  dailyFatTargetG     Int           @map("daily_fat_target_g")
  waterTargetMl       Int           @default(2000) @map("water_target_ml")
  sleepTargetHours    Decimal       @default(7.5) @map("sleep_target_hours")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_profiles_user_id")
  @@map("user_profiles")
}

model DailyNutrition {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  recordDate     DateTime @map("record_date")
  totalCalories  Int      @default(0) @map("total_calories")
  totalProteinG  Decimal  @default(0) @map("total_protein_g")
  totalCarbsG    Decimal  @default(0) @map("total_carbs_g")
  totalFatG      Decimal  @default(0) @map("total_fat_g")
  caloriesTarget Int      @map("calories_target")
  proteinTargetG Int      @map("protein_target_g")
  carbsTargetG   Int      @map("carbs_target_g")
  fatTargetG     Int      @map("fat_target_g")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, recordDate])
  @@index([userId, recordDate], map: "idx_daily_nutrition_user_date")
  @@map("daily_nutrition")
}

model FoodCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  sortOrder Int      @default(0) @map("sort_order")
  icon      String?
  isSystem  Boolean  @default(true) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at")

  foodItems FoodItem[]

  @@index([sortOrder], map: "idx_food_categories_sort")
  @@map("food_categories")
}

model FoodItem {
  id              String   @id @default(uuid())
  name            String
  categoryId      String   @map("category_id")
  caloriesPer100g Int      @map("calories_per_100g")
  proteinPer100g  Decimal  @default(0) @map("protein_per_100g")
  carbsPer100g    Decimal  @default(0) @map("carbs_per_100g")
  fatPer100g      Decimal  @default(0) @map("fat_per_100g")
  unit            String   @default("g")
  isSystem        Boolean  @default(true) @map("is_system")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  category  FoodCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  mealFoods MealFood[]

  @@index([categoryId], map: "idx_food_items_category")
  @@index([name], map: "idx_food_items_name")
  @@index([isSystem, isActive], map: "idx_food_items_system_active")
  @@map("food_items")
}

model MealRecord {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  recordDate    DateTime @map("record_date")
  mealType      MealType @map("meal_type")
  totalCalories Int      @default(0) @map("total_calories")
  totalProteinG Decimal  @default(0) @map("total_protein_g")
  totalCarbsG   Decimal  @default(0) @map("total_carbs_g")
  totalFatG     Decimal  @default(0) @map("total_fat_g")
  note          String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealFoods MealFood[]

  @@index([userId, recordDate], map: "idx_meal_records_user_date")
  @@index([userId, recordDate, mealType], map: "idx_meal_records_user_date_type")
  @@map("meal_records")
}

model MealFood {
  id                 String   @id @default(uuid())
  mealRecordId       String   @map("meal_record_id")
  foodItemId         String   @map("food_item_id")
  quantityG          Decimal  @map("quantity_g")
  calculatedCalories Int      @map("calculated_calories")
  calculatedProteinG Decimal  @map("calculated_protein_g")
  calculatedCarbsG   Decimal  @map("calculated_carbs_g")
  calculatedFatG     Decimal  @map("calculated_fat_g")
  createdAt          DateTime @default(now()) @map("created_at")

  mealRecord MealRecord @relation(fields: [mealRecordId], references: [id], onDelete: Cascade)
  foodItem   FoodItem   @relation(fields: [foodItemId], references: [id], onDelete: Restrict)

  @@index([mealRecordId], map: "idx_meal_foods_meal")
  @@index([foodItemId], map: "idx_meal_foods_food")
  @@map("meal_foods")
}

model FoodPhoto {
  id                 String      @id @default(uuid())
  userId             String      @map("user_id")
  recognizedFoodName String?     @map("recognized_food_name")
  proteinG           Decimal?    @map("protein_g")
  carbsG             Decimal?    @map("carbs_g")
  fatG               Decimal?    @map("fat_g")
  status             PhotoStatus @default(pending)
  errorMessage       String?     @map("error_message")
  createdAt          DateTime    @default(now()) @map("created_at")
  completedAt        DateTime?   @map("completed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt], map: "idx_food_photos_user")
  @@map("food_photos")
}

model HealthChecklist {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  recordDate       DateTime @map("record_date")
  waterIntake      Boolean  @default(false) @map("water_intake")
  sleepQuality     Boolean  @default(false) @map("sleep_quality")
  exerciseDone     Boolean  @default(false) @map("exercise_done")
  waterIntakeMl    Int      @default(0) @map("water_intake_ml")
  sleepActualHours Decimal? @map("sleep_actual_hours")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, recordDate])
  @@index([userId, recordDate], map: "idx_health_checklist_user_date")
  @@map("health_checklist")
}

model HealthScore {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  recordDate     DateTime @map("record_date")
  totalScore     Int      @map("total_score")
  grade          String
  nutritionScore Int      @map("nutrition_score")
  exerciseScore  Int      @map("exercise_score")
  sleepScore     Int      @map("sleep_score")
  hydrationScore Int      @map("hydration_score")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, recordDate])
  @@index([userId, recordDate], map: "idx_health_scores_user_date")
  @@map("health_scores")
}

model ExerciseCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  sortOrder Int      @default(0) @map("sort_order")
  icon      String?
  isSystem  Boolean  @default(true) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at")

  exercises Exercise[]

  @@index([sortOrder], map: "idx_exercise_categories_sort")
  @@map("exercise_categories")
}

model Exercise {
  id                 String   @id @default(uuid())
  name               String
  categoryId         String   @map("category_id")
  description        String?
  isCardio           Boolean  @default(false) @map("is_cardio")
  defaultSets        Int?     @map("default_sets")
  defaultReps        Int?     @map("default_reps")
  defaultDurationMin Int?     @map("default_duration_min")
  isSystem           Boolean  @default(true) @map("is_system")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")

  category         ExerciseCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  workoutExercises WorkoutExercise[]

  @@index([categoryId], map: "idx_exercises_category")
  @@index([name], map: "idx_exercises_name")
  @@index([isCardio], map: "idx_exercises_cardio")
  @@index([isSystem, isActive], map: "idx_exercises_system_active")
  @@map("exercises")
}

model WorkoutRecord {
  id                 String        @id @default(uuid())
  userId             String        @map("user_id")
  workoutDate        DateTime      @map("workout_date")
  startTime          DateTime?     @map("start_time")
  endTime            DateTime?     @map("end_time")
  totalDurationMin   Int           @default(0) @map("total_duration_min")
  totalExercises     Int           @default(0) @map("total_exercises")
  totalSetsCompleted Int           @default(0) @map("total_sets_completed")
  status             WorkoutStatus @default(in_progress)
  notes              String?
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutExercises WorkoutExercise[]

  @@index([userId, workoutDate], map: "idx_workout_records_user_date")
  @@index([userId, status], map: "idx_workout_records_status")
  @@map("workout_records")
}

model WorkoutExercise {
  id              String   @id @default(uuid())
  workoutRecordId String   @map("workout_record_id")
  exerciseId      String   @map("exercise_id")
  exerciseOrder   Int      @default(0) @map("exercise_order")
  setNumber       Int      @default(1) @map("set_number")
  weightKg        Decimal? @map("weight_kg")
  reps            Int?
  durationMin     Decimal? @map("duration_min")
  inclinePercent  Decimal? @map("incline_percent")
  resistanceLevel Int?     @map("resistance_level")
  loadSetting     String?  @map("load_setting")
  isCompleted     Boolean  @default(false) @map("is_completed")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  workoutRecord WorkoutRecord @relation(fields: [workoutRecordId], references: [id], onDelete: Cascade)
  exercise      Exercise      @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@index([workoutRecordId, exerciseOrder, setNumber], map: "idx_workout_exercises_workout")
  @@index([exerciseId], map: "idx_workout_exercises_exercise")
  @@map("workout_exercises")
}

model AppSetting {
  id           String           @id @default(uuid())
  userId       String           @map("user_id")
  settingKey   String           @map("setting_key")
  settingValue String           @map("setting_value")
  valueType    SettingValueType @default(string) @map("value_type")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, settingKey])
  @@index([userId, settingKey], map: "idx_app_settings_user_key")
  @@map("app_settings")
}

model SystemInfo {
  id                   String   @id @default(uuid())
  appName              String   @map("app_name")
  appVersion           String   @map("app_version")
  buildNumber          String?  @map("build_number")
  releaseNotes         String?  @map("release_notes")
  privacyPolicyContent String?  @map("privacy_policy_content")
  developerName        String?  @map("developer_name")
  developerTitle       String?  @map("developer_title")
  isCurrent            Boolean  @default(false) @map("is_current")
  createdAt            DateTime @default(now()) @map("created_at")

  @@index([isCurrent], map: "idx_system_info_current")
  @@map("system_info")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt], map: "idx_refresh_tokens_user")
  @@index([tokenHash], map: "idx_refresh_tokens_hash")
  @@index([expiresAt], map: "idx_refresh_tokens_expires")
  @@map("refresh_tokens")
}
